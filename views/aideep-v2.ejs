<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= book.title %> - AI助读 - 仙宝心灵成长</title>
<link href="/fontawesome/css/all.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
<style>
@font-face{font-family:'Noto Serif SC';src:url('/assets/xianbao/NotoSerifSC-SemiBold.subset.woff2')format('woff2');font-weight:600;font-display:swap}*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:-apple-system,BlinkMacSystemFont,'Noto Sans SC','PingFang SC','Hiragino Sans GB',sans-serif;font-size:1rem;h1,h2,h3{font-family:'Songti SC','Noto Serif SC','STSong','SimSun',serif;font-weight:600}background:#f8f5f0;color:#1f2937;padding-top:44px;}
a{color:#7c3aed;text-decoration:none;}

/* Nav */
/* Layout */
.page-layout{display:flex;max-width:1200px;margin:0 auto;padding:24px 20px 60px;gap:24px;align-items:flex-start;}

/* Sidebar */
.sidebar{width:240px;min-width:240px;position:sticky;top:84px;}
.sidebar-card{background:white;border-radius:14px;border:1px solid rgba(0,0,0,.04);overflow:hidden;}
.sidebar-title{font-size:1rem;font-weight:700;color:#6b7280;padding:14px 16px 8px;text-transform:uppercase;letter-spacing:.5px;}
.category-item{display:flex;align-items:center;gap:8px;padding:10px 16px;cursor:pointer;font-size:1rem;color:#4b5563;border-left:3px solid transparent;transition:.15s;}
.category-item:hover{background:#f5f3ff;color:#7c3aed;}
.category-item.active{background:#faf5ff;color:#7c3aed;border-left-color:#7c3aed;font-weight:600;}
.category-item .cat-icon{font-size:1rem;width:24px;text-align:center;}
.category-item .cat-count{font-size:1rem;color:#9ca3af;margin-left:auto;}
.sidebar-stats{padding:12px 16px;border-top:1px solid #f3f4f6;font-size:1rem;color:#9ca3af;display:flex;justify-content:space-between;}

/* Main content */
.content-area{flex:1;min-width:0;}

/* Header */
.aideep-header{background:linear-gradient(135deg,#fffbeb,#fef3c7);border-radius:20px;padding:28px 32px;margin-bottom:20px;border:1px solid rgba(245,158,11,.15);}
.aideep-header h1{font-size:1.4rem;font-weight:800;color:#92400e;margin-bottom:4px;display:flex;align-items:center;gap:10px;}
.aideep-header .sub{font-size:1rem;color:#b45309;}
.aideep-header .badge{display:inline-flex;align-items:center;gap:6px;background:rgba(245,158,11,.15);padding:4px 12px;border-radius:100px;font-size:1rem;color:#92400e;margin-top:8px;}

/* Category section */
.category-section{display:none;}
.category-section.active{display:block;}
.cat-header{display:flex;align-items:center;gap:12px;margin-bottom:16px;padding-bottom:12px;border-bottom:2px solid #fef3c7;}
.cat-header .cat-icon-large{font-size:1.8rem;width:44px;height:44px;display:flex;align-items:center;justify-content:center;background:#fffbeb;border-radius:12px;}
.cat-header h2{font-size:1.15rem;font-weight:700;color:#1f2937;}
.cat-header .cat-desc{font-size:1rem;color:#6b7280;margin-top:2px;}

/* Theme card */
.theme-card{background:white;border-radius:14px;border:1px solid rgba(0,0,0,.04);margin-bottom:12px;overflow:hidden;transition:.2s;}
.theme-card:hover{box-shadow:0 2px 12px rgba(0,0,0,.04);}
.theme-header{display:flex;align-items:flex-start;padding:16px 20px;cursor:pointer;gap:12px;user-select:none;}
.theme-header .theme-num{width:28px;height:28px;border-radius:50%;background:#f5f3ff;display:flex;align-items:center;justify-content:center;font-size:1rem;font-weight:700;color:#7c3aed;flex-shrink:0;margin-top:2px;}
.theme-header .theme-info{flex:1;min-width:0;}
.theme-header .theme-info h3{font-size:1rem;font-weight:700;color:#1f2937;margin-bottom:3px;}
.theme-header .theme-info .summary{font-size:1rem;color:#6b7280;line-height:1.5;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;}
.theme-toggle{color:#9ca3af;font-size:1rem;transition:.2s;margin-top:4px;flex-shrink:0;}
.theme-card.expanded .theme-toggle{transform:rotate(180deg);color:#7c3aed;}

/* Theme body (expandable) */
.theme-body{display:none;padding:0 20px 20px;border-top:1px solid #f3f4f6;}
.theme-card.expanded .theme-body{display:block;}
.theme-body .section-label{font-size:1rem;font-weight:700;color:#7c3aed;text-transform:uppercase;letter-spacing:.5px;margin:16px 0 8px;padding-bottom:4px;border-bottom:1px solid #f3f4f6;}
.theme-body .section-label:first-child{margin-top:4px;}
.theme-body .concept-tag{display:inline-block;padding:3px 10px;border-radius:100px;font-size:1rem;background:#f5f3ff;color:#7c3aed;margin:2px 4px 2px 0;font-weight:500;}
.theme-body .content-text{font-size:1rem;line-height:1.8;color:#374151;}
.theme-body .passage-box{background:#faf5ff;border-radius:10px;padding:14px 18px;font-size:1rem;line-height:1.7;color:#4b5563;border-left:3px solid #7c3aed;margin:8px 0;}
.theme-body .passage-box blockquote{background:#f5f3ff;padding:8px 12px;margin:8px 0;border-left:3px solid #7c3aed;border-radius:0 6px 6px 0;color:#4b5563;font-style:italic;}
.theme-body .passage-box p{margin:4px 0;}
.theme-body .practice-box{background:#f0fdf4;border-radius:10px;padding:14px 18px;font-size:1rem;line-height:1.7;color:#374151;border-left:3px solid #22c55e;margin:8px 0;}
.theme-body .practice-box ol{padding-left:20px;margin:8px 0;}
.theme-body .practice-box li{margin:6px 0;line-height:1.6;}
.theme-body .practice-box p{margin:4px 0;}
.theme-body .xref-link{display:inline-block;padding:3px 10px;border-radius:100px;font-size:1rem;background:#fffbeb;color:#d97706;margin:2px 4px 2px 0;font-weight:500;cursor:pointer;}
.theme-body .xref-link:hover{background:#fef3c7;}

/* Loading */
.loading{text-align:center;padding:60px 20px;color:#9ca3af;}
.loading .spinner{display:inline-block;width:32px;height:32px;border:3px solid #f3f4f6;border-top-color:#7c3aed;border-radius:50%;animation:spin .6s linear infinite;margin-bottom:12px;}
@keyframes spin{to{transform:rotate(360deg);}}

/* Empty state */
.empty-state{text-align:center;padding:40px 20px;color:#9ca3af;}
.empty-state .emoji{font-size:2.8rem;margin-bottom:12px;}

/* Progress dot */
.progress-dot{display:inline-block;width:6px;height:6px;border-radius:50%;margin-left:4px;}
.progress-dot.complete{background:#22c55e;}

footer{background:#1e1b4b;margin-top:40px;}
.footer-inner{max-width:1200px;margin:0 auto;padding:28px 20px;text-align:center;color:rgba(255,255,255,.4);font-size:1rem;}

@media(max-width:768px){
  .page-layout{flex-direction:column;}
  .sidebar{width:100%;position:static;}
  .sidebar .category-item{display:inline-flex;padding:6px 12px;border-left:none;border-bottom:2px solid transparent;}
  .sidebar .category-item.active{border-bottom-color:#7c3aed;}
  .sidebar .category-item .cat-count{display:none;}
  .sidebar-card{overflow-x:auto;white-space:nowrap;}
  .sidebar .sidebar-title,.sidebar-stats{display:none;}
  .aideep-header{padding:20px;}
  .aideep-header h1{font-size:1.15rem;}
  .theme-header{padding:12px 16px;}
  .theme-body{padding:0 16px 16px;}
}

/* First theme highlight */
.first-theme{
  background:linear-gradient(135deg,#faf5ff,#ffffff);
  border:1px solid rgba(124,58,237,.1);
}
.first-theme .theme-num{background:#7c3aed;color:white;}


</style>

<link rel="stylesheet" href="/assets/xianbao/xianbao-topbar.css">
</head>
<body>
<div id="xianbao-topbar" data-active="reading"></div>

<div class="page-layout">
  <!-- Sidebar -->
  <aside class="sidebar">
    <div class="sidebar-card">
      <div class="sidebar-title">📑 主题分类</div>
      <div id="categoryList"></div>
      <div class="sidebar-stats">
        <span>共 <span id="totalCatCount"><%= categories.length %></span> 分类</span>
        <span><span id="totalThemeCount"><%= totalThemes %></span> 个主题</span>
      </div>
    </div>
  </aside>

  <!-- Main -->
  <main class="content-area">
    <div class="aideep-header">
      <h1>🤖 <%= book.title %></h1>
      <div class="sub">AI深度助读 · 结构化主题分析 · 分类导航</div>
      <div class="badge"><i class="fas fa-robot"></i> AI生成 · 基于全书精读与原文分析</div>
    </div>

    <div id="loading" class="loading">
      <div class="spinner"></div>
      <div>正在加载主题数据...</div>
    </div>

    <div id="contentContainer" style="display:none;"></div>
  </main>
</div>

<footer>
  <div class="footer-inner">
    <p>© 2026 仙宝心灵成长 · 探索内在世界，点亮心灵之光</p>
  </div>
</footer>

<script>
// 分类数据
const categories = <%- JSON.stringify(categories) %>;
const bookId = <%= book.id %>;

// 缓存已加载的主题
const themeCache = {};

let activeCategoryId = null;

// ---- 初始化侧边栏 ----
function renderSidebar() {
  const list = document.getElementById('categoryList');
  list.innerHTML = categories.map(c => `
    <div class="category-item${c.id === activeCategoryId ? ' active' : ''}" data-cat-id="${c.id}" onclick="switchCategory(${c.id})">
      <span class="cat-icon">${c.icon || '📚'}</span>
      <span>${c.name}</span>
      <span class="cat-count">${c.theme_count || 0}</span>
    </div>
  `).join('');
}

// ---- 切换分类 ----
async function switchCategory(catId) {
  activeCategoryId = catId;
  
  // 更新侧边栏高亮
  document.querySelectorAll('.category-item').forEach(el => {
    el.classList.toggle('active', parseInt(el.dataset.catId) === catId);
  });
  
  // 加载主题
  if (themeCache[catId]) {
    renderThemes(catId, themeCache[catId]);
  } else {
    showLoading('加载主题中...');
    try {
      const res = await fetch(`/api/books/${bookId}/aideep-themes/${catId}`);
      const data = await res.json();
      if (data.ok) {
        themeCache[catId] = data;
        renderThemes(catId, data);
      }
    } catch(e) {
      showLoading('加载失败，请重试');
    }
  }
}

// ---- 渲染主题 ----
function renderThemes(catId, data) {
  const container = document.getElementById('contentContainer');
  
  const cat = categories.find(c => c.id === catId);
  if (!cat) return;
  
  // 构建HTML
  let html = `
    <div class="cat-header">
      <div class="cat-icon-large">${cat.icon || '📚'}</div>
      <div>
        <h2>${cat.name}</h2>
        <div class="cat-desc">${cat.description || ''}</div>
      </div>
    </div>
  `;
  
  if (!data.themes || data.themes.length === 0) {
    html += `<div class="empty-state"><div class="emoji">📭</div><p>该分类暂无主题内容</p></div>`;
  } else {
    data.themes.forEach((theme, idx) => {
      const isFirst = idx === 0;
      html += `
        <div class="theme-card${isFirst ? ' first-theme' : ''}" id="theme-${theme.id}">
          <div class="theme-header" onclick="toggleTheme(${theme.id})">
            <div class="theme-num">${idx + 1}</div>
            <div class="theme-info">
              <h3>${theme.title}</h3>
              <div class="summary">${theme.summary || '点击展开详细内容'}</div>
            </div>
            <div class="theme-toggle"><i class="fas fa-chevron-down"></i></div>
          </div>
          <div class="theme-body">
            ${theme.overview ? `<div class="section-label">📖 概述</div><div class="content-text">${marked.parse(theme.overview)}</div>` : ''}
            ${theme.keyConcepts && theme.keyConcepts.length > 0 ? `
              <div class="section-label">🔑 核心概念</div>
              <div>${theme.keyConcepts.map(c => `<span class="concept-tag">${c}</span>`).join('')}</div>
            ` : ''}
            ${theme.coreContent ? `<div class="section-label">📝 详细阐述</div><div class="content-text">${marked.parse(theme.coreContent)}</div>` : ''}
            ${theme.relatedPassages ? `<div class="section-label">📜 原文佐证</div><div class="passage-box">${marked.parse(theme.relatedPassages)}</div>` : ''}
            ${theme.practicalApplication ? `<div class="section-label">💡 实践应用</div><div class="practice-box">${marked.parse(theme.practicalApplication)}</div>` : ''}
          </div>
        </div>
      `;
    });
  }
  
  container.innerHTML = html;
  container.style.display = 'block';
  document.getElementById('loading').style.display = 'none';
}

// ---- 展开/折叠 ----
function toggleTheme(themeId) {
  const card = document.getElementById('theme-' + themeId);
  if (card) {
    card.classList.toggle('expanded');
  }
}

// ---- Loading ----
function showLoading(msg) {
  document.getElementById('contentContainer').style.display = 'none';
  document.getElementById('loading').innerHTML = `
    <div class="spinner"></div>
    <div>${msg || '加载中...'}</div>
  `;
  document.getElementById('loading').style.display = 'block';
}

// ---- 初始化 ----
renderSidebar();
if (categories.length > 0) {
  switchCategory(categories[0].id);
}
</script>
<script src="/assets/xianbao/auth-widget.js"></script>
<script>
(function(){
  var OV="rlOverlay";
  function showOV(){
    if(document.getElementById(OV))return;
    var d=document.createElement("div");
    d.id=OV;
    d.style.cssText="position:fixed;inset:0;z-index:9999;background:rgba(10,14,26,.95);display:flex;flex-direction:column;align-items:center;justify-content:center;padding:40px;text-align:center;";
    d.innerHTML='<div style="font-size:2.8rem;margin-bottom:20px;">👤</div><div style="color:#f0f0f0;font-size:1.4rem;font-weight:700;margin-bottom:12px;">请登录后阅读</div><div style="color:#94a3b8;font-size:1rem;line-height:1.7;max-width:320px;margin-bottom:28px;">注册并登录即可免费阅读全部书籍<br>升级VIP可无限阅读所有内容</div><button onclick="XianbaoAuth.showLogin()" style="padding:12px 36px;background:linear-gradient(135deg,#7c3aed,#6d28d9);color:#fff;border:none;border-radius:100px;font-size:1rem;font-weight:700;cursor:pointer;">登录 / 注册</button><a href="/" style="display:inline-block;margin-top:16px;color:#64748b;font-size:1rem;text-decoration:none;">← 返回首页</a>';
    document.body.appendChild(d);
  }
  function hideOV(){var o=document.getElementById(OV);if(o)o.remove()}
  function chk(t){
    t=t||30;
    if(typeof XianbaoAuth==="undefined"){if(t>0)setTimeout(function(){chk(t-1)},200);return}
    if(!XianbaoAuth.isLoggedIn())showOV();else hideOV()
  }
  chk();
  if(typeof XianbaoAuth!=="undefined"&&XianbaoAuth.onAuthChange){
    XianbaoAuth.onAuthChange(function(s){if(s.loggedIn)hideOV();else showOV()})
  }
})();
</script>
<script src="/assets/xianbao/xianbao-topbar.js"></script>
</body>
</html>
