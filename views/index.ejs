<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
<meta http-equiv="Pragma" content="no-cache">
<meta http-equiv="Expires" content="0">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>灵修阅读站 · 探索内在世界</title>
<link href="/fontawesome/css/all.min.css" rel="stylesheet">
<style>
@font-face{font-family:'Noto Serif SC';src:url('/assets/xianbao/NotoSerifSC-SemiBold.subset.woff2')format('woff2');font-weight:600;font-display:swap}
*{margin:0;padding:0;box-sizing:border-box;}
body{
  font-family:-apple-system,BlinkMacSystemFont,'Noto Sans SC','PingFang SC','Hiragino Sans GB',sans-serif;
  font-size:1rem;
  background:#0B0E1A;
  color:#E8E6F0;
  padding-top:44px;
  min-height:100vh;
}
h1,h2,h3{font-family:'Songti SC','Noto Serif SC','STSong','SimSun',serif;font-weight:600}
a{color:#C8A65C;text-decoration:none;transition:opacity .2s;}
a:hover{opacity:.75;}

/* ===== HERO ===== */
.hero{
  position:relative;
  min-height:520px;
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  text-align:center;
  overflow:hidden;
  padding:80px 20px 30px;
}
.hero-bg{
  position:absolute;inset:0;
  background:url('/images/hero-bg.jpg') center/cover no-repeat;
  filter:brightness(.5) saturate(1.2);
  z-index:0;
}
.hero-bg::after{
  content:'';
  position:absolute;inset:0;
  background:linear-gradient(180deg,rgba(11,14,26,.3) 0%,rgba(11,14,26,.85) 70%,#0B0E1A 100%);
}
.hero-content{position:relative;z-index:1;max-width:700px;}
.hero-badge{
  display:inline-block;
  padding:5px 16px;
  border:1px solid rgba(200,166,92,.3);
  border-radius:100px;
  font-size:12px;letter-spacing:2px;color:#C8A65C;
  margin-bottom:20px;
}
.hero h1{
  font-size:46px;font-weight:700;
  color:#fff;
  margin-bottom:12px;
  letter-spacing:6px;
  text-shadow:0 2px 20px rgba(0,0,0,.5);
}
.hero .sub{
  font-size:16px;color:rgba(232,230,240,.6);
  line-height:1.8;max-width:500px;margin:0 auto;
  font-family:'Songti SC','Noto Serif SC','STSong',serif;
  letter-spacing:1px;
}
.hero .sub em{color:#C8A65C;font-style:normal;}

/* Daily quote */
.hero-quote{
  margin-top:28px;
  padding:14px 24px;
  background:rgba(255,255,255,.04);
  border-left:2px solid rgba(200,166,92,.4);
  border-radius:4px;
  max-width:540px;
  font-family:'Songti SC','Noto Serif SC',serif;
  font-size:15px;line-height:1.7;
  color:rgba(232,230,240,.75);
}
.hero-quote .q-source{font-size:12px;color:rgba(200,166,92,.5);margin-top:6px;}

/* Stats */
.stats{
  position:relative;z-index:1;
  display:flex;gap:1px;
  margin-top:40px;
  border-radius:12px;
  overflow:hidden;
  background:rgba(255,255,255,.06);
  backdrop-filter:blur(12px);
  -webkit-backdrop-filter:blur(12px);
  border:1px solid rgba(255,255,255,.06);
}
.stat{
  padding:16px 32px;
  text-align:center;
  background:rgba(255,255,255,.02);
  min-width:110px;
}
.stat+.stat{border-left:1px solid rgba(255,255,255,.05);}
.stat .num{
  font-size:28px;font-weight:700;
  background:linear-gradient(135deg,#C8A65C,#E8C87A);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  background-clip:text;
}
.stat .lbl{font-size:12px;color:rgba(232,230,240,.5);margin-top:2px;letter-spacing:1px;}

/* ===== CONTAINER ===== */
.container{max-width:1100px;margin:0 auto;padding:0 20px 40px;}

/* ===== FEATURED SECTION ===== */
.section-header{
  display:flex;align-items:center;gap:10px;
  margin:50px 0 20px;
}
.section-header .line{flex:1;height:1px;background:linear-gradient(90deg,rgba(200,166,92,.3),transparent);}
.section-header h2{
  font-size:18px;font-weight:600;color:#C8A65C;
  letter-spacing:3px;white-space:nowrap;
}

.featured-grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:16px;
}
.featured-card{
  position:relative;
  border-radius:14px;
  overflow:hidden;
  border:1px solid rgba(255,255,255,.06);
  transition:transform .3s,box-shadow .3s;
  cursor:pointer;
  text-decoration:none;color:inherit;
  display:flex;
  flex-direction:column;
}
.featured-card:hover{
  transform:translateY(-3px);
  box-shadow:0 12px 32px rgba(0,0,0,.4);
}
.featured-card .fc-cover{
  height:180px;
  display:flex;flex-direction:column;justify-content:flex-end;
  padding:18px 20px;
  position:relative;
}
.featured-card .fc-cover .fc-tag{
  font-size:11px;color:rgba(255,255,255,.5);
  letter-spacing:1px;margin-bottom:4px;
}
.featured-card .fc-cover .fc-title{
  font-size:17px;font-weight:700;color:#fff;
  font-family:'Songti SC','Noto Serif SC',serif;
}
.featured-card .fc-body{
  padding:14px 20px;
  display:flex;align-items:center;justify-content:space-between;
  background:rgba(255,255,255,.02);
}
.featured-card .fc-body .fc-info{font-size:13px;color:rgba(232,230,240,.5);}
.featured-card .fc-body .fc-action{
  font-size:13px;color:#C8A65C;
  display:flex;align-items:center;gap:4px;
}
.featured-card.featured-main .fc-cover{height:220px;}
.featured-card.featured-main{grid-row:span 2;}

/* ===== FEATURED 4-CARD GRID ===== */
.featured-grid-4{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:14px;
}
.fc4-card{
  position:relative;
  border-radius:14px;
  overflow:hidden;
  border:1px solid rgba(255,255,255,.08);
  transition:all .35s;
  text-decoration:none;color:inherit;
  display:block;
}
.fc4-card:hover{
  transform:translateY(-4px);
  box-shadow:0 12px 32px rgba(0,0,0,.5);
  border-color:rgba(200,166,92,.3);
}
.fc4-cover{
  aspect-ratio:3/4;
  display:flex;
  flex-direction:column;
  justify-content:flex-end;
  padding:20px;
  position:relative;
  background-size:cover;
  background-position:center;
  background-repeat:no-repeat;
}
.fc4-overlay{
  position:absolute;inset:0;
  background:linear-gradient(0deg,rgba(0,0,0,.7) 0%,rgba(0,0,0,.15) 50%,rgba(0,0,0,.05) 100%);
  pointer-events:none;
}
.fc4-tag{
  position:relative;z-index:1;
  font-size:11px;color:rgba(255,255,255,.5);
  letter-spacing:1px;margin-bottom:6px;
}
.fc4-title{
  position:relative;z-index:1;
  font-size:20px;font-weight:700;color:#fff;
  font-family:'Songti SC','Noto Serif SC',serif;
  margin-bottom:4px;
  line-height:1.3;
}
.fc4-desc{
  position:relative;z-index:1;
  font-size:12px;color:rgba(255,255,255,.45);
}

.fc4-cover-1{background-image:url('/images/cover-yushenduihua.jpg');}
.fc4-cover-2{background-image:url('/images/cover-taishatianshu.jpg');}
.fc4-cover-3{background-image:url('/images/cover-lingxingchengzhang.jpg');}
.fc4-cover-4{background-image:url('/images/cover-moushengzhidao.jpg');}

@media(max-width:900px){
  .featured-grid-4{grid-template-columns:repeat(2,1fr);}
}
@media(max-width:500px){
  .featured-grid-4{grid-template-columns:repeat(2,1fr);gap:10px;}
  .fc4-cover{aspect-ratio:3/4;height:auto;background-size:contain;background-color:rgba(255,255,255,.03);}
  .fc4-cover-1{background-image:url('/images/cover-yushenduihua-mobile.jpg');}
  .fc4-cover-2{background-image:url('/images/cover-taishatianshu-mobile.jpg');}
  .fc4-cover-3{background-image:url('/images/cover-lingxingchengzhang-mobile.jpg');}
  .fc4-cover-4{background-image:url('/images/cover-moushengzhidao-mobile.jpg');}
}


/* ===== CATEGORY GRID ===== */
.cat-title{
  display:flex;align-items:center;gap:10px;
  margin:36px 0 14px;
  cursor:pointer;
  user-select:none;
}
.cat-title .ct-icon{font-size:18px;}
.cat-title .ct-name{
  font-size:16px;font-weight:600;color:#E8E6F0;
  font-family:'Songti SC','Noto Serif SC',serif;
}
.cat-title .ct-count{font-size:13px;color:rgba(232,230,240,.35);}
.cat-title .ct-more{
  margin-left:auto;
  font-size:13px;color:rgba(200,166,92,.6);
  transition:color .2s;
}
.cat-title .ct-more:hover{color:#C8A65C;}

.book-grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(200px,1fr));
  gap:12px;
}
.book-card{
  background:rgba(255,255,255,.03);
  border:1px solid rgba(255,255,255,.05);
  border-radius:10px;
  overflow:hidden;
  transition:all .25s;
  text-decoration:none;color:inherit;
}
.book-card:hover{
  background:rgba(255,255,255,.06);
  border-color:rgba(200,166,92,.2);
  transform:translateY(-2px);
}
.book-card .bc-cover{
  height:70px;
  display:flex;flex-direction:column;justify-content:flex-end;
  padding:10px 14px;
}
.book-card .bc-cover .bc-tag{
  font-size:10px;color:rgba(255,255,255,.4);
  letter-spacing:1px;margin-bottom:2px;
}
.book-card .bc-cover .bc-title{
  font-size:14px;font-weight:600;color:#fff;
  font-family:'Songti SC','Noto Serif SC',serif;
  display:-webkit-box;-webkit-line-clamp:1;-webkit-box-orient:vertical;overflow:hidden;
}
.book-card .bc-body{
  padding:8px 14px 10px;
  display:flex;justify-content:space-between;align-items:center;
}
.book-card .bc-body .bc-info{
  font-size:12px;color:rgba(232,230,240,.35);
}
.book-card .bc-body .bc-badge{
  font-size:10px;padding:1px 8px;border-radius:100px;
  border:1px solid rgba(200,166,92,.2);
  color:rgba(200,166,92,.6);
}

/* ===== FOOTER ===== */
footer{
  margin-top:60px;
  border-top:1px solid rgba(255,255,255,.04);
  background:rgba(0,0,0,.2);
}
footer .footer-inner{
  max-width:1100px;margin:0 auto;
  padding:32px 20px;
  text-align:center;
  color:rgba(232,230,240,.3);
  font-size:13px;
}
footer .footer-inner a{color:rgba(200,166,92,.4);}

/* ===== RANDOM BUTTON ===== */
.random-btn{
  position:fixed;bottom:28px;right:28px;
  z-index:100;
  width:48px;height:48px;
  border-radius:50%;
  background:linear-gradient(135deg,#C8A65C,#A8853A);
  border:none;
  color:#0B0E1A;
  font-size:18px;
  cursor:pointer;
  box-shadow:0 4px 16px rgba(200,166,92,.25);
  transition:transform .25s,box-shadow .25s;
  display:flex;align-items:center;justify-content:center;
}
.random-btn:hover{
  transform:scale(1.1);
  box-shadow:0 6px 24px rgba(200,166,92,.35);
}

/* ===== ANIMATIONS ===== */
@keyframes fadeUp{
  from{opacity:0;transform:translateY(20px)}
  to{opacity:1;transform:translateY(0)}
}
.hero-content,.stats{animation:fadeUp .6s ease-out both;}
.stats{animation-delay:.2s;}

/* ===== RESPONSIVE ===== */
@media(max-width:700px){
  .hero h1{font-size:32px;letter-spacing:4px;}
  .hero{min-height:420px;padding:60px 16px 20px;}
  .stat{padding:12px 18px;min-width:80px;}
  .stat .num{font-size:22px;}
  .featured-grid{grid-template-columns:1fr;}
  .featured-card.featured-main{grid-row:auto;}
  .featured-card .fc-cover,.featured-card.featured-main .fc-cover{height:140px;}
  .book-grid{grid-template-columns:repeat(auto-fill,minmax(160px,1fr));}
  .hero-quote{font-size:14px;padding:12px 16px;}
}
</style>

<link rel="icon" type="image/x-icon" href="/assets/xianbao/favicon.ico">
<link rel="icon" type="image/png" sizes="16x16" href="/assets/xianbao/favicon-16.png">
<link rel="icon" type="image/png" sizes="32x32" href="/assets/xianbao/favicon-32.png">
<link rel="icon" type="image/png" sizes="192x192" href="/assets/xianbao/favicon-256.png">
<link rel="apple-touch-icon" sizes="180x180" href="/assets/xianbao/apple-touch-icon.png">
<link rel="stylesheet" href="/assets/xianbao/xianbao-topbar.css">
</head>
<body>
<div id="xianbao-topbar" data-active="reading"></div>

<!-- HERO -->
<div class="hero">
  <div class="hero-bg"></div>
  <div class="hero-content">
    <div class="hero-badge">✦ 灵性经典 · 免费阅读</div>
    <h1>灵修阅读站</h1>
    <p class="sub">在文字中照见本心，于静默里遇见真我<br>赛斯 · 欧林 · 与神对话 · <em>一的法则</em> · 克里希那穆提</p>
    <% if (quote) { %>
    <div class="hero-quote">
      &ldquo;<%= quote.text %>&rdquo;
      <div class="q-source">—— <%= quote.source %></div>
    </div>
    <% } %>
  </div>
  <div class="stats">
    <div class="stat"><div class="num"><%= stats.books %></div><div class="lbl">部经典</div></div>
    <div class="stat"><div class="num"><%= Math.round(stats.chars/10000) %>万</div><div class="lbl">字智慧</div></div>
    <div class="stat"><div class="num"><%= cats.length %></div><div class="lbl">大系列</div></div>
  </div>
</div>

<div class="container">

  <!-- FEATURED: 精选阅读 -->
  <div class="section-header">
    <h2>精选阅读</h2>
    <div class="line"></div>
  </div>

  <div class="featured-grid-4">
    <a href="/books/33" class="fc4-card">
      <div class="fc4-cover fc4-cover-1">
        <div class="fc4-overlay"></div>
        <div class="fc4-tag">★ 与神对话</div>
<div class="fc4-desc">39万字 · 直抵灵魂的对话</div>
      </div>
    </a>
    <a href="/books/88" class="fc4-card">
      <div class="fc4-cover fc4-cover-2">
        <div class="fc4-overlay"></div>
        <div class="fc4-tag">★ 太傻天书</div>
<div class="fc4-desc">47万字 · 超越时间的心灵指南</div>
      </div>
    </a>
    <a href="/books/82" class="fc4-card">
      <div class="fc4-cover fc4-cover-3">
        <div class="fc4-overlay"></div>
        <div class="fc4-tag">★ 欧林系列</div>
<div class="fc4-desc">11万字 · 点亮内在之光</div>
      </div>
    </a>
    <a href="/books/110" class="fc4-card">
      <div class="fc4-cover fc4-cover-4">
        <div class="fc4-overlay"></div>
        <div class="fc4-tag">★ 克里希那穆提</div>
<div class="fc4-desc">9万字 · 正确的生活之道</div>
      </div>
    </a>
  </div>

  <!-- CATEGORY SECTIONS -->
  <% cats.forEach(c => { %>
    <% if (c.books.length > 0) { %>
      <div class="cat-title">
        <span class="ct-icon"><%= c.icon || '📖' %></span>
        <span class="ct-name"><%= c.name %></span>
        <span class="ct-count"><%= c.books.length %>部</span>
        <a href="/books?cat=<%= c.slug %>" class="ct-more">全部 →</a>
      </div>
      <div class="book-grid">
        <% c.books.forEach(b => { %>
          <a href="/books/<%= b.id %>" class="book-card">
            <div class="bc-cover" style="background:linear-gradient(135deg,<%= ['#2d1b69,#4a2c8a','#4a1a2e,#7a2e4e','#3a2a0a,#5a4a1a','#0d3328,#146354','#1a2040,#2a3a6a','#2a0a3a,#5a1a5a'][(b.id||c.id)%6] %>)">
              <div class="bc-tag"><%= c.name %></div>
              <div class="bc-title"><%= b.title %></div>
            </div>
            <div class="bc-body">
              <span class="bc-info"><%= Math.round(b.total_chars/10000) %>万字</span>
              <span class="bc-badge">免费</span>
            </div>
          </a>
        <% }) %>
      </div>
    <% } %>
  <% }) %>
</div>

<!-- Random book button -->
<button class="random-btn" onclick="location.href='/books/<%= Math.floor(Math.random()*stats.books+1) %>'" title="随机翻开一本书">
  <i class="fas fa-dice-d6"></i>
</button>

<footer>
  <div class="footer-inner">
    <p>&copy; 2026 灵修阅读站 · 探索内在世界，点亮心灵之光</p>
    <p style="margin-top:6px;"><a href="https://beian.miit.gov.cn/" target="_blank" rel="noopener">渝ICP备2026008822号-1</a></p>
  </div>
</footer>

<script src="/assets/xianbao/auth-widget.js"></script>
<script src="/assets/xianbao/xianbao-topbar.js"></script>
</body>
</html>
