<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>灵修阅读站</title>
<link href="/fontawesome/css/all.min.css" rel="stylesheet">
<style>
@font-face{font-family:'Noto Serif SC';src:url('/assets/xianbao/NotoSerifSC-SemiBold.subset.woff2')format('woff2');font-weight:600;font-display:swap}*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:-apple-system,BlinkMacSystemFont,'Noto Sans SC','PingFang SC','Hiragino Sans GB',sans-serif;font-size:1rem;h1,h2,h3{font-family:'Songti SC','Noto Serif SC','STSong','SimSun',serif;font-weight:600}background:#f8f5f0;color:#1f2937;padding-top:44px;}
a{color:#7c3aed;text-decoration:none;}
a:hover{opacity:.8;}

/* Navigation */

/* Hero */
.hero{background:linear-gradient(135deg,#1e1b4b,#581c87);padding:100px 20px 70px;text-align:center;color:white;}
.hero h1{font-size:38px;font-weight:800;margin-bottom:10px;}
.hero p{font-size:16px;color:rgba(255,255,255,.65);max-width:540px;margin:0 auto;line-height:1.7;}

/* Stats */
.stats{display:flex;gap:12px;justify-content:center;margin-top:-20px;position:relative;z-index:2;flex-wrap:wrap;}
.stat{background:white;border-radius:12px;padding:14px 24px;text-align:center;box-shadow:0 2px 12px rgba(0,0,0,.06);min-width:100px;}
.stat .num{font-size:26px;font-weight:800;background:linear-gradient(135deg,#7c3aed,#ec4899);-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.stat .lbl{font-size:14px;color:#6b7280;margin-top:2px;}

/* Book grid */
.container{max-width:1100px;margin:0 auto;padding:40px 20px;}
.section-title{font-size:20px;font-weight:700;margin:40px 0 16px;display:flex;align-items:center;gap:8px;}
.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:16px;}
.card{background:white;border-radius:12px;overflow:hidden;border:1px solid rgba(0,0,0,.04);transition:.2s;text-decoration:none;color:inherit;}
.card:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,0,0,.08);}
.cover{height:90px;padding:14px 18px;display:flex;flex-direction:column;justify-content:flex-end;}
.cover .ctag{font-size:14px;opacity:.7;color:white;}
.cover .ctitle{font-size:15px;font-weight:700;color:white;}
.cbody{padding:10px 14px;display:flex;justify-content:space-between;align-items:center;}
.cbody .info{font-size:14px;color:#6b7280;}
.cbody .badge{font-size:14px;padding:2px 10px;border-radius:100px;font-weight:600;}
.cbody .badge-free{background:#d1fae5;color:#059669;}

/* Hero book section */
.hero-book{margin-bottom:32px;}
.hero-book-inner{background:linear-gradient(135deg,#7c3aed,#6d28d9);border-radius:16px;padding:32px;color:white;display:flex;align-items:center;gap:24px;flex-wrap:wrap;}
.hero-book .icon{width:64px;height:64px;border-radius:12px;background:rgba(255,255,255,.15);display:flex;align-items:center;justify-content:center;font-size:28px;flex-shrink:0;}
.hero-book .info{flex:1;min-width:200px;}
.hero-book .info h2{font-size:22px;margin-bottom:6px;}
.hero-book .info p{font-size:14px;opacity:.8;line-height:1.5;}
.hero-book .action{flex-shrink:0;}
.hero-book .action .btn{display:inline-block;padding:10px 24px;border-radius:100px;font-size:14px;font-weight:600;text-decoration:none;background:white;color:#7c3aed;}

footer{background:#1e1b4b;margin-top:60px;}
footer .footer-inner{max-width:1100px;margin:0 auto;padding:28px 20px;text-align:center;color:rgba(255,255,255,.4);font-size:14px;}
</style>

<link rel="icon" type="image/x-icon" href="/assets/xianbao/favicon.ico">
<link rel="icon" type="image/png" sizes="16x16" href="/assets/xianbao/favicon-16.png">
<link rel="icon" type="image/png" sizes="32x32" href="/assets/xianbao/favicon-32.png">
<link rel="icon" type="image/png" sizes="192x192" href="/assets/xianbao/favicon-256.png">
<link rel="apple-touch-icon" sizes="180x180" href="/assets/xianbao/apple-touch-icon.png">

<link rel="stylesheet" href="/assets/xianbao/xianbao-topbar.css">
</head>
<body>
<div id="xianbao-topbar" data-active="reading"></div>

<div class="hero">
  <h1>灵修阅读站</h1>
  <p>探索内在世界，点亮心灵之光。<br>赛斯、欧林、与神对话、《一的法则》等灵性经典汇集</p>
</div>

<div class="stats">
  <div class="stat"><div class="num"><%= stats.books %></div><div class="lbl">部经典</div></div>
  <div class="stat"><div class="num"><%= Math.round(stats.chars/10000) %>万</div><div class="lbl">字内容</div></div>
  <div class="stat"><div class="num"><%= cats.length %></div><div class="lbl">大分类</div></div>
</div>

<div class="container">
  <!-- Featured: 一的法则 -->
  <div class="hero-book">
    <div class="hero-book-inner">
      <div class="icon">🌌</div>
      <div class="info">
        <h2>一的法则（全集）</h2>
        <p>与星际社会记忆复合体RA的对话，揭示宇宙实相——涵盖宇宙创造、灵性进化、能量治疗的完整教导</p>
      </div>
      <div class="action">
        <a href="/books/6" class="btn">进入阅读 <i class="fas fa-arrow-right"></i></a>
      </div>
    </div>
  </div>

  <!-- Category sections -->
  <% cats.forEach(c => { %>
    <% if (c.books.length > 0) { %>
      <div class="section-title">
        <span><%= c.icon || '📖' %></span>
        <span><%= c.name %></span>
        <span style="font-size:14px;font-weight:400;color:#9ca3af;">（<%= c.books.length %>部）</span>
        <a href="/books?cat=<%= c.slug %>" style="font-size:14px;font-weight:400;margin-left:auto;color:#7c3aed;">查看全部 →</a>
      </div>
      <div class="grid">
        <% c.books.forEach(b => { %>
          <a href="/books/<%= b.id %>" class="card">
            <div class="cover" style="background:linear-gradient(135deg,<%= ['#7c3aed,#6d28d9','#ec4899,#be185d','#f59e0b,#d97706','#059669,#047857','#6366f1,#4f46e5','#db2777,#be123c'][(b.id||c.id)%6] %>)">
              <div class="ctag"><%= c.name %></div>
              <div class="ctitle"><%= b.title %></div>
            </div>
            <div class="cbody">
              <span class="info"><%= Math.round(b.total_chars/10000) %>万字</span>
              <span class="badge badge-free">免费</span>
            </div>
          </a>
        <% }) %>
      </div>
    <% } %>
  <% }) %>
</div>

<footer>
  <div class="footer-inner">
    <p>© 2026 灵修阅读站 · 探索内在世界，点亮心灵之光</p>
    <p style="margin-top:6px;"><a href="https://beian.miit.gov.cn/" target="_blank" rel="noopener" style="color:rgba(255,255,255,.4);">渝ICP备2026008822号-1</a></p>
  </div>
</footer>
<script src="/assets/xianbao/auth-widget.js"></script>
<script src="/assets/xianbao/xianbao-topbar.js"></script>

</body>
</html>
