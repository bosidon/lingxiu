<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>管理后台 - 仙宝心灵成长</title>
<link href="/fontawesome/css/all.min.css" rel="stylesheet">
<style>
@font-face{font-family:'Noto Serif SC';src:url('/assets/xianbao/NotoSerifSC-SemiBold.subset.woff2')format('woff2');font-weight:600;font-display:swap}*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:-apple-system,BlinkMacSystemFont,'Noto Sans SC','PingFang SC','Hiragino Sans GB',sans-serif;font-size:1rem;h1,h2,h3{font-family:'Songti SC','Noto Serif SC','STSong','SimSun',serif;font-weight:600}background:#f8f5f0;color:#1f2937;padding-top:44px;}
a{color:#7c3aed;text-decoration:none;}
.container{max-width:900px;margin:0 auto;padding:40px 20px;}
h1{font-size:24px;margin-bottom:24px;}
.stats-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:32px;}
.stat-card{background:white;border-radius:10px;padding:20px;text-align:center;border:1px solid rgba(0,0,0,.04);}
.stat-num{font-size:28px;font-weight:800;color:#7c3aed;}
.stat-lbl{font-size:14px;color:#6b7280;margin-top:4px;}
.admin-links{display:flex;gap:12px;}
.btn{display:inline-block;padding:10px 22px;border-radius:100px;font-size:14px;font-weight:600;text-decoration:none;background:linear-gradient(135deg,#7c3aed,#6d28d9);color:white;}


<link rel="stylesheet" href="/assets/xianbao/xianbao-topbar.css">
</head>
<body>
<div id="xianbao-topbar" data-active="reading"></div><div class="container">
  <h1>📊 仪表盘</h1>
  <div class="stats-grid">
    <div class="stat-card"><div class="stat-num"><%= st.books %></div><div class="stat-lbl">书籍</div></div>
    <div class="stat-card"><div class="stat-num"><%= st.chapters %></div><div class="stat-lbl">章节</div></div>
    <div class="stat-card"><div class="stat-num"><%= st.summaries %></div><div class="stat-lbl">精读总结</div></div>
  </div>
  <div class="admin-links">
    <a href="/admin/books" class="btn">书籍管理</a>
  </div>
</div>
<script src="/assets/xianbao/xianbao-topbar.js"></script>
</body>
</html>
