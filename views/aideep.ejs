<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= book.title %> - AI助读 - 灵修阅读站</title>
<link href="/fontawesome/css/all.min.css" rel="stylesheet">
<style>
@font-face{font-family:'Noto Serif SC';src:url('/assets/xianbao/NotoSerifSC-SemiBold.subset.woff2')format('woff2');font-weight:600;font-display:swap}*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:-apple-system,BlinkMacSystemFont,'Noto Sans SC','PingFang SC','Hiragino Sans GB',sans-serif;font-size:1rem;h1,h2,h3{font-family:'Songti SC','Noto Serif SC','STSong','SimSun',serif;font-weight:600}background:#f8f5f0;color:#1f2937;padding-top:44px;}
a{color:#7c3aed;text-decoration:none;}
.container{max-width:900px;margin:0 auto;padding:20px;}
.back-link{display:inline-block;font-size:1rem;color:#7c3aed;margin-bottom:16px;}
.aideep-header{background:linear-gradient(135deg,#fffbeb,#fef3c7);border-radius:20px;padding:32px 36px;margin-bottom:28px;border:1px solid rgba(245,158,11,.15);}
.aideep-header h1{font-size:1.4rem;font-weight:800;color:#92400e;margin-bottom:8px;display:flex;align-items:center;gap:12px;}
.aideep-header .sub{font-size:1rem;color:#b45309;}
.aideep-header .badge{display:inline-flex;align-items:center;gap:6px;background:rgba(245,158,11,.15);padding:4px 12px;border-radius:100px;font-size:1rem;color:#92400e;margin-top:10px;}
.aideep-body{background:white;border-radius:20px;padding:36px 40px;line-height:2;font-size:1rem;color:#374151;border:1px solid rgba(0,0,0,.04);}
.aideep-layout{display:flex;gap:24px;align-items:flex-start;}
.aideep-toc{width:220px;min-width:220px;position:sticky;top:80px;background:white;border-radius:14px;padding:16px 0;border:1px solid rgba(0,0,0,.04);max-height:calc(100vh - 100px);overflow-y:auto;}
.toc-title{font-size:1rem;font-weight:700;color:#1f2937;padding:0 16px 10px;border-bottom:1px solid #f3f4f6;margin-bottom:4px;}
.toc-item{display:block;font-size:1rem;color:#6b7280;padding:7px 16px;text-decoration:none;transition:.15s;border-left:3px solid transparent;}
.toc-item:hover{background:#f5f3ff;color:#7c3aed;}
.toc-item.active{background:#fffbeb;color:#92400e;border-left-color:#f59e0b;font-weight:600;}
.aideep-body{flex:1;min-width:0;background:white;border-radius:20px;padding:36px 40px;line-height:2;font-size:1rem;color:#374151;border:1px solid rgba(0,0,0,.04);}
.aideep-body h3{font-size:1.15rem;font-weight:700;color:#92400e;margin:28px 0 12px;padding-bottom:8px;border-bottom:2px solid #fef3c7;}
.aideep-body h4{font-size:1rem;font-weight:700;color:#1f2937;margin:18px 0 8px;}
.aideep-body p{margin-bottom:1em;text-indent:2em;}
.aideep-body ul{padding-left:24px;margin:8px 0;}
.aideep-body li{margin-bottom:8px;line-height:1.8;}
.aideep-body strong{color:#92400e;}
.aideep-body blockquote{border-left:4px solid #f59e0b;padding:12px 20px;margin:16px 0;background:#fffbeb;border-radius:0 10px 10px 0;font-style:italic;color:#78350f;}
footer{background:#1e1b4b;margin-top:60px;}
.footer-inner{max-width:900px;margin:0 auto;padding:28px 20px;text-align:center;color:rgba(255,255,255,.4);font-size:1rem;}
@media(max-width:768px){
  .aideep-body{padding:20px 18px;font-size:1rem;}
  .aideep-header{padding:24px 20px;}
  .aideep-header h1{font-size:1.4rem;}
}

</style>
<link rel="icon" type="image/x-icon" href="/assets/xianbao/favicon.ico">
<link rel="icon" type="image/png" sizes="16x16" href="/assets/xianbao/favicon-16.png">
<link rel="icon" type="image/png" sizes="32x32" href="/assets/xianbao/favicon-32.png">
<link rel="icon" type="image/png" sizes="192x192" href="/assets/xianbao/favicon-256.png">
<link rel="apple-touch-icon" sizes="180x180" href="/assets/xianbao/apple-touch-icon.png">

<link rel="stylesheet" href="/assets/xianbao/xianbao-topbar.css">
<div id="xianbao-topbar" data-active="reading"></div>

<div class="container">
  <a href="/books/<%= book.id %>" class="back-link">← 返回<%= book.title %></a>

  <div class="aideep-header">
    <h1>🤖 <%= book.title %></h1>
    <div class="sub">AI助读报告 · 基于DeepSeek AI对全书内容的深度分析</div>
    <div class="badge"><i class="fas fa-robot"></i> AI生成 · 仅供参考</div>

  <div class="aideep-layout">
    <!-- 侧边目录 -->
    <nav class="aideep-toc" id="toc">
      <div class="toc-title">📑 目录</div>
      <div class="toc-list" id="tocList"></div>
    </nav>

    <!-- 正文 -->
    <div class="aideep-body" id="aideepBody">
      <!-- 一句话速览（由JS自动生成） -->
      <div id="quickSummary" style="display:none;background:#faf5ff;border-radius:14px;padding:20px 24px;margin-bottom:24px;border:1px solid rgba(124,58,237,.1);">
        <h4 style="font-size:1rem;font-weight:700;color:#7c3aed;margin-bottom:12px;display:flex;align-items:center;gap:8px;">📋 主题速览</h4>
        <div id="summaryList"></div>
      <%- content %>

<script>
// 自动生成目录
(function() {
  const body = document.getElementById('aideepBody');
  const toc = document.getElementById('tocList');
  const headers = body.querySelectorAll('h3');
  
  // 生成一句话速览
  const summaryList = document.getElementById('summaryList');
  const summaryBox = document.getElementById('quickSummary');
  
  headers.forEach((h, i) => {
    const id = 'section-' + i;
    h.id = id;
    
    // 提取该章节下的第一句话（第一个p标签）
    let p = h.nextElementSibling;
    let firstSentence = '';
    while (p) {
      if (p.tagName === 'P' && p.textContent.trim().length > 10) {
        firstSentence = p.textContent.trim().substring(0, 120);
        if (firstSentence.length >= 120) firstSentence += '...';
        break;
      }
      p = p.nextElementSibling;
    }
    
    // 速览条目
    if (firstSentence) {
      const item = document.createElement('div');
      item.style.cssText = 'display:flex;align-items:flex-start;gap:8px;padding:5px 0;font-size:1rem;color:#4b5563;line-height:1.5;';
      item.innerHTML = '<span style="color:#7c3aed;font-weight:600;white-space:nowrap;">' + h.textContent.replace(/^[📚🏛️🌍🧬🗺️💡🤔🎯]+/, '').substring(0, 18) + '</span><span style="color:#9ca3af;">—</span><span>' + firstSentence + '</span>';
      summaryList.appendChild(item);
    }
    
    // 侧边目录项
    const a = document.createElement('a');
    a.href = '#' + id;
    a.className = 'toc-item';
    a.textContent = h.textContent.replace(/^[📚🏛️🌍🧬🗺️💡🤔🎯]+\s*/g, '');
    a.addEventListener('click', function(e) {
      e.preventDefault();
      document.querySelectorAll('.toc-item').forEach(el => el.classList.remove('active'));
      this.classList.add('active');
      document.getElementById(id).scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
    toc.appendChild(a);
  });
  
  if (summaryList.children.length > 0) {
    summaryBox.style.display = 'block';
  }
  
  // 滚动时高亮当前章节
  window.addEventListener('scroll', function() {
    let current = '';
    headers.forEach((h, i) => {
      const rect = h.getBoundingClientRect();
      if (rect.top <= 120) current = h.id;
    });
    document.querySelectorAll('.toc-item').forEach(el => {
      el.classList.toggle('active', el.getAttribute('href') === '#' + current);
    });
  });
})();
</script>

<footer>
  <div class="footer-inner">
    <p>© 2026 灵修阅读站 · 探索内在世界，点亮心灵之光</p>
</footer>
<script src="/assets/xianbao/auth-widget.js"></script>
<script>

(function(){
  var OV="rlOverlay";
  function showOV(){
    if(document.getElementById(OV))return;
    var d=document.createElement("div");
    d.id=OV;
    d.style.cssText="position:fixed;inset:0;z-index:9999;background:rgba(10,14,26,.95);display:flex;flex-direction:column;align-items:center;justify-content:center;padding:40px;text-align:center;";
    d.innerHTML='<div style="font-size:2.8rem;margin-bottom:20px;">👤</div><div style="color:#f0f0f0;font-size:1.4rem;font-weight:700;margin-bottom:12px;">请登录后阅读</div><div style="color:#94a3b8;font-size:1rem;line-height:1.7;max-width:320px;margin-bottom:28px;">注册并登录即可免费阅读全部书籍<br>升级VIP可无限阅读所有内容</div><button onclick=\"XianbaoAuth.showLogin()\" style=\"padding:12px 36px;background:linear-gradient(135deg,#7c3aed,#6d28d9);color:#fff;border:none;border-radius:100px;font-size:1rem;font-weight:700;cursor:pointer;\">登录 / 注册</button><a href=\"/\" style=\"display:inline-block;margin-top:16px;color:#64748b;font-size:1rem;text-decoration:none;\">← 返回首页</a>';
    document.body.appendChild(d);
  }
  function hideOV(){var o=document.getElementById(OV);if(o)o.remove()}
  function chk(t){
    t=t||30;
    if(typeof XianbaoAuth==="undefined"){if(t>0)setTimeout(function(){chk(t-1)},200);return}
    if(!XianbaoAuth.isLoggedIn())showOV();else hideOV()
  }
  chk();
  if(typeof XianbaoAuth!=="undefined"&&XianbaoAuth.onAuthChange){
    XianbaoAuth.onAuthChange(function(s){if(s.loggedIn)hideOV();else showOV()})
  }
})();
</script>
<script src="/assets/xianbao/xianbao-topbar.js"></script>

</body>
</html>
