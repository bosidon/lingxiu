<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= book.title %> - 灵修阅读器</title>
<link href="/fontawesome/css/all.min.css" rel="stylesheet">
<link rel="stylesheet" href="/assets/xianbao/xianbao-topbar.css">
<style>
@font-face{font-family:'Noto Serif SC';src:url('/assets/xianbao/NotoSerifSC-SemiBold.subset.woff2')format('woff2');font-weight:600;font-display:swap}
*{margin:0;padding:0;box-sizing:border-box;}
body{
  font-family:-apple-system,BlinkMacSystemFont,'Noto Sans SC','PingFang SC','Hiragino Sans GB',sans-serif;
  font-size:1rem;
  background:#0B0E1A;
  color:#E8E6F0;
  padding-top:44px;
  height:100vh;
  overflow:hidden;
}
h1,h2,h3{font-family:'Songti SC','Noto Serif SC','STSong','SimSun',serif;font-weight:600}
a{color:#C8A65C;text-decoration:none;transition:opacity .2s;}
a:hover{opacity:.75;}

.reader-wrapper{
  display:flex;
  height:calc(100vh - 44px);
  max-width:1400px;
  margin:0 auto;
  justify-content:center;
  border-left:1px solid rgba(255,255,255,.04);
  border-right:1px solid rgba(255,255,255,.04);
}
.reader-wrapper.with-images{justify-content:flex-start;}

.sidebar{
  width:260px;min-width:260px;
  background:rgba(255,255,255,.02);
  border-right:1px solid rgba(255,255,255,.05);
  overflow-y:auto;
  display:flex;flex-direction:column;
}

.sidebar{
  width:260px;min-width:260px;
  background:rgba(255,255,255,.02);
  border-right:1px solid rgba(255,255,255,.05);
  overflow-y:auto;
  display:flex;flex-direction:column;
}
.sidebar-header{
  padding:16px 16px 10px;
  border-bottom:1px solid rgba(255,255,255,.05);
}
.sidebar-header h2{font-size:14px;font-weight:600;color:#E8E6F0;display:-webkit-box;-webkit-line-clamp:1;-webkit-box-orient:vertical;overflow:hidden;}
.sidebar-header .back-link{font-size:12px;color:rgba(200,166,92,.6);margin-top:4px;display:inline-block;}

.chapter-list{flex:1;overflow-y:auto;padding:4px 0;}
.chapter-item{
  display:flex;align-items:center;
  padding:8px 16px;cursor:pointer;
  transition:background .15s;gap:8px;
  border-left:2px solid transparent;
}
.chapter-item:hover{background:rgba(255,255,255,.04);}
.chapter-item.active{background:rgba(200,166,92,.08);border-left-color:#C8A65C;}
.chapter-item .ch-num{
  width:20px;height:20px;border-radius:50%;
  background:rgba(255,255,255,.06);
  display:flex;align-items:center;justify-content:center;
  font-size:11px;color:rgba(232,230,240,.4);flex-shrink:0;
}
.chapter-item.active .ch-num{background:rgba(200,166,92,.2);color:#C8A65C;}
.chapter-item .ch-title{
  font-size:13px;color:rgba(232,230,240,.6);flex:1;
  line-height:1.3;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;
}
.chapter-item.active .ch-title{color:#E8E6F0;font-weight:500;}
.chapter-item .has-summary{width:5px;height:5px;border-radius:50%;background:rgba(200,166,92,.3);flex-shrink:0;}

.content-area{
  flex:1;overflow-y:auto;padding:24px 32px 60px;
  max-width:780px;min-width:0;
}
.content-header{
  display:flex;justify-content:space-between;align-items:center;
  margin-bottom:16px;flex-wrap:wrap;gap:8px;
}
.content-title{font-size:18px;font-weight:700;color:#E8E6F0;}
.mode-toggle{display:flex;background:rgba(255,255,255,.05);border-radius:100px;padding:3px;font-size:13px;}
.mode-btn{
  padding:4px 12px;border-radius:100px;border:none;background:transparent;
  color:rgba(232,230,240,.4);cursor:pointer;
  font-size:13px;font-weight:500;transition:.2s;
}
.mode-btn.active{background:rgba(200,166,92,.2);color:#C8A65C;}
.mode-btn:hover:not(.active){color:rgba(232,230,240,.7);}

.content-body{
  background:rgba(255,255,255,.03);
  border-radius:12px;padding:24px 28px;
  line-height:2;font-size:15px;
  color:rgba(232,230,240,.85);
  border:1px solid rgba(255,255,255,.05);
}
.content-body h2{font-size:16px;margin:16px 0 8px;color:#E8E6F0;}
.content-body h3{font-size:14px;margin:12px 0 6px;color:#E8E6F0;}
.content-body p{margin-bottom:1em;text-indent:2em;}
.content-body ul{padding-left:20px;margin:8px 0;}
.content-body li{margin-bottom:6px;}
.content-body blockquote{
  border-left:2px solid rgba(200,166,92,.3);
  padding:8px 16px;margin:12px 0;
  background:rgba(200,166,92,.04);
  border-radius:0 8px 8px 0;color:rgba(232,230,240,.7);
}

.key-points{
  background:rgba(200,166,92,.05);border-radius:10px;
  padding:14px 18px;margin-bottom:16px;
  border:1px solid rgba(200,166,92,.1);
}
.key-points h4{font-size:13px;margin-bottom:8px;color:#C8A65C;display:flex;align-items:center;gap:6px;}
.kp-item{display:flex;align-items:flex-start;gap:8px;padding:4px 0;font-size:13px;color:rgba(232,230,240,.65);line-height:1.5;}
.kp-dot{width:5px;height:5px;border-radius:50%;background:rgba(200,166,92,.3);flex-shrink:0;margin-top:7px;}

.empty-state{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:80px 20px;color:rgba(232,230,240,.3);text-align:center;}
.empty-state i{font-size:40px;margin-bottom:14px;}
.empty-state p{font-size:14px;line-height:1.6;}
.loading{display:flex;align-items:center;justify-content:center;padding:60px;color:rgba(232,230,240,.3);}
.spinner{width:20px;height:20px;border:2px solid rgba(255,255,255,.06);border-top-color:#C8A65C;border-radius:50%;animation:spin .6s linear infinite;margin-right:10px;}
@keyframes spin{to{transform:rotate(360deg)}}

.image-sidebar{
  width:0;min-width:0;overflow:hidden;
  background:rgba(255,255,255,.02);
  border-left:1px solid rgba(255,255,255,.05);
  transition:width .3s,min-width .3s;display:flex;flex-direction:column;
}
.image-sidebar.has-images{width:220px;min-width:220px;}
.image-sidebar-header{padding:12px 14px 10px;border-bottom:1px solid rgba(255,255,255,.05);font-size:13px;font-weight:600;color:rgba(232,230,240,.5);display:flex;align-items:center;gap:6px;}
.image-sidebar-list{flex:1;overflow-y:auto;padding:8px;}
.image-sidebar-list .img-thumb{display:block;margin-bottom:8px;border-radius:6px;overflow:hidden;border:1px solid rgba(255,255,255,.05);cursor:pointer;transition:.2s;}
.image-sidebar-list .img-thumb:hover{border-color:rgba(200,166,92,.3);}
.image-sidebar-list .img-thumb img{width:100%;height:auto;display:block;}
.image-sidebar-list .img-caption{font-size:11px;color:rgba(232,230,240,.3);padding:4px 6px 5px;text-align:center;}

.usage-banner{
  display:none;
  background:rgba(200,166,92,.08);border:1px solid rgba(200,166,92,.15);
  border-radius:10px;padding:10px 16px;margin-bottom:14px;
  align-items:center;justify-content:space-between;gap:10px;
}
.usage-banner .banner-text{font-size:13px;color:rgba(200,166,92,.7);line-height:1.5;}
.usage-banner .banner-text i{color:#C8A65C;}
.usage-banner .upgrade-btn{padding:6px 16px;background:linear-gradient(135deg,#C8A65C,#A8853A);color:#0B0E1A;border:none;border-radius:100px;font-size:13px;font-weight:600;cursor:pointer;text-decoration:none;}

.hamburger{display:none;}
.overlay{display:none;}

@media(max-width:1024px){.image-sidebar.has-images{width:180px;min-width:180px;}}
@media(max-width:768px){
  #xianbao-topbar,.xianbao-topbar{display:none;}
  body{padding-top:0;}
  .reader-wrapper{height:100dvh;}
  .sidebar{position:fixed;left:-260px;top:0;bottom:0;z-index:50;transition:left .3s;background:#0B0E1A;border-right:1px solid rgba(255,255,255,.08);}
  .sidebar.open{left:0;}
  .sidebar.open + .overlay{display:block;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:49;}
  .hamburger{display:flex;align-items:center;justify-content:center;width:32px;height:32px;border:none;background:transparent;font-size:18px;color:rgba(232,230,240,.6);cursor:pointer;margin-right:8px;}
  .content-area{padding:0 16px 16px;}
  .content-header{position:sticky;top:0;z-index:10;background:#0B0E1A;padding:12px 0 10px;}
  .content-body{padding:16px 18px;font-size:14px;}
  .reader-wrapper{border:none;}
  .image-sidebar{display:none;}
}

/* 细读模式 - 覆盖旧浅色主题硬编码 */
.reading-content [style*="background:#fefce8"]{
  background:rgba(200,166,92,.08) !important;
  border-left-color:rgba(200,166,92,.35) !important;
}
.reading-content [style*="background:#f0f4ff"]{
  background:rgba(59,130,246,.08) !important;
  border-left-color:rgba(59,130,246,.35) !important;
}
.reading-content [style*="background:#f3f4f6"],
.reading-content [style*="background:#f9fafb"]{
  background:rgba(255,255,255,.04) !important;
}
</style>
</head>
<body>
<div id="xianbao-topbar" data-active="reading"></div>

<div class="reader-wrapper">
  <div class="sidebar" id="sidebar">
    <div class="sidebar-header">
      <h2><%= book.title %></h2>
      <a href="/books/<%= book.id %>" class="back-link">&larr; 返回书籍</a>
    </div>
    <div class="chapter-list">
      <% chapters.forEach((ch, i) => { %>
        <div class="chapter-item<%= i === 0 ? ' active' : '' %>" data-ch-id="<%= ch.id %>" onclick="loadChapter(<%= ch.id %>)">
          <span class="ch-num"><%= i+1 %></span>
          <span class="ch-title"><%= ch.title %></span>
          <% if (summaryMap[ch.id]) { %><span class="has-summary"></span><% } %>
        </div>
      <% }) %>
    </div>
  </div>
  <div class="overlay" onclick="toggleSidebar()"></div>

  <div class="content-area" id="contentArea">
    <div class="content-header">
      <div style="display:flex;align-items:center;gap:4px;">
        <button class="hamburger" onclick="toggleSidebar()">&#9776;</button>
        <h1 class="content-title" id="contentTitle">选择章节</h1>
      </div>
      <div class="mode-toggle">
        <button class="mode-btn active" id="modeSummary" onclick="switchMode('summary')">&#x1F4D6; 精读</button>
        <button class="mode-btn" id="modeReading" onclick="switchMode('reading')">&#x1F4DD; 细读</button>
      </div>
    </div>

    <div id="usageBanner" class="usage-banner">
      <span class="banner-text"><i class="fas fa-info-circle"></i> 免费版可查看3本书</span>
      <a href="https://xianbao.online/vip.html" class="upgrade-btn" target="_blank">升级VIP</a>
    </div>

    <div id="keyPointsContainer" style="display:none;"></div>

    <div id="contentBody" class="content-body">
      <div class="empty-state" id="welcomeState">
        <i class="fas fa-book-open"></i>
        <p><strong>灵修阅读器</strong><br>点击左侧目录选择章节</p>
      </div>
      <div class="loading" id="loadingState" style="display:none;"><div class="spinner"></div>加载中...</div>
    </div>
  </div>

  <div class="image-sidebar" id="imageSidebar">
    <div class="image-sidebar-header"><i class="fas fa-image"></i> 插图</div>
    <div class="image-sidebar-list" id="imageSidebarList"></div>
  </div>
</div>

<script>
var currentBookId = <%= book.id %>;
var currentChId = null;
var currentMode = 'summary';

function toggleSidebar() {
  document.getElementById('sidebar').classList.toggle('open');
}

function showLoading() {
  document.getElementById('contentBody').innerHTML = '<div class="loading"><div class="spinner"></div>加载中...</div>';
}

function loadChapter(chId) {
  currentChId = chId;
  document.querySelectorAll('.chapter-item').forEach(function(el) { el.classList.remove('active'); });
  var el = document.querySelector('.chapter-item[data-ch-id="' + chId + '"]');
  if (el) el.classList.add('active');
  document.getElementById('sidebar').classList.remove('open');
  var ws = document.getElementById('welcomeState'); if(ws) ws.style.display = 'none';
  var kpc = document.getElementById('keyPointsContainer'); if(kpc) kpc.style.display = 'none';
  showLoading();
  fetchData(chId, currentMode);
}

function fetchData(chId, mode) {
  fetch('/api/books/' + currentBookId + '/chapter/' + chId + '?mode=' + mode)
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (!data.ok) {
        if (mode === 'summary') {
          document.getElementById('modeSummary').className = 'mode-btn';
          document.getElementById('modeReading').className = 'mode-btn active';
          currentMode = 'reading';
          fetchData(chId, 'reading');
          return;
        }
        document.getElementById('contentBody').innerHTML = '<div class="empty-state"><p>暂无内容</p></div>';
        return;
      }
      document.getElementById('contentTitle').textContent = data.title;

      if (mode === 'summary' && data.needUpgrade) {
        document.getElementById('usageBanner').style.display = 'flex';
        document.getElementById('modeSummary').className = 'mode-btn';
        document.getElementById('modeReading').className = 'mode-btn active';
        currentMode = 'reading';
        fetchData(chId, 'reading');
        return;
      } else {
        document.getElementById('usageBanner').style.display = 'none';
      }

      if (mode === 'summary' && data.keyPoints && data.keyPoints.length > 0) {
        var kpDiv = document.getElementById('keyPointsContainer');
        kpDiv.innerHTML = '<div class="key-points"><h4><i class="fas fa-list-check"></i> 核心要点</h4>' +
          data.keyPoints.map(function(kp) { return '<div class="kp-item"><span class="kp-dot"></span><span>' + kp + '</span></div>'; }).join('') + '</div>';
        kpDiv.style.display = 'block';
      } else {
        var kpc = document.getElementById('keyPointsContainer'); if(kpc) kpc.style.display = 'none';
      }

      document.getElementById('contentBody').innerHTML = '<div class="' + (mode === 'reading' ? 'reading-content' : '') + '">' + data.content + '</div>';

      var imgSidebar = document.getElementById('imageSidebar');
      var imgList = document.getElementById('imageSidebarList');
      if (data.images && data.images.length > 0) {
        imgSidebar.classList.add('has-images');
        document.querySelector('.reader-wrapper').classList.add('with-images');
        imgList.innerHTML = data.images.map(function(img) {
          return '<a class="img-thumb" href="' + img.src + '" target="_blank"><img src="' + img.src + '" alt="" loading="lazy" /><div class="img-caption">' + (img.label || '第' + img.page + '页') + '</div></a>';
        }).join('');
      } else {
        imgSidebar.classList.remove('has-images');
        document.querySelector('.reader-wrapper').classList.remove('with-images');
        imgList.innerHTML = '';
      }
    })
    .catch(function() {
      document.getElementById('contentBody').innerHTML = '<div class="empty-state"><p>加载失败</p></div>';
    });
}

function switchMode(mode) {
  currentMode = mode;
  document.getElementById('modeSummary').className = 'mode-btn' + (mode === 'summary' ? ' active' : '');
  document.getElementById('modeReading').className = 'mode-btn' + (mode === 'reading' ? ' active' : '');
  if (currentChId) { showLoading(); fetchData(currentChId, mode); }
}

function loadChapterFromHash() {
  var hash = window.location.hash;
  if (hash && hash.indexOf('#chapter-') === 0) {
    var chId = hash.replace('#chapter-', '');
    var el = document.querySelector('.chapter-item[data-ch-id="' + chId + '"]');
    if (el) { loadChapter(parseInt(chId)); return; }
  }
  var first = document.querySelector('.chapter-item');
  if (first) { loadChapter(parseInt(first.dataset.chId)); }
}

window.addEventListener('DOMContentLoaded', loadChapterFromHash);
window.addEventListener('hashchange', loadChapterFromHash);

var origLoad = window.loadChapter;
window.loadChapter = function(chId) {
  history.pushState(null, '', '#chapter-' + chId);
  return origLoad(chId);
};
</script>
<script src="/assets/xianbao/auth-widget.js"></script>
<script src="/assets/xianbao/xianbao-topbar.js"></script>
</body>
</html>
