<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>会员中心 - 灵修阅读站</title>
<link href="/fontawesome/css/all.min.css" rel="stylesheet">
<style>
@font-face{font-family:'Noto Serif SC';src:url('/assets/xianbao/NotoSerifSC-SemiBold.subset.woff2')format('woff2');font-weight:600;font-display:swap}*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:-apple-system,BlinkMacSystemFont,'Noto Sans SC','PingFang SC','Hiragino Sans GB',sans-serif;font-size:1rem;h1,h2,h3{font-family:'Songti SC','Noto Serif SC','STSong','SimSun',serif;font-weight:600}background:#f8f5f0;color:#1f2937;padding-top:92px;}
.container{max-width:800px;margin:0 auto;padding:40px 20px;}
h1{font-size:28px;margin-bottom:24px;}
.card{background:white;border-radius:12px;padding:24px;margin-bottom:16px;}
.plans{display:grid;grid-template-columns:1fr 1fr;gap:16px;max-width:500px;margin:0 auto;}
.plan{background:white;border-radius:12px;padding:28px;text-align:center;border:1px solid rgba(0,0,0,.04);}
.plan.featured{border:2px solid #f59e0b;position:relative;}
.plan.featured::before{content:'推荐';position:absolute;top:-10px;right:12px;background:#f59e0b;color:white;font-size:14px;padding:2px 10px;border-radius:100px;font-weight:600;}
.plan .price{font-size:32px;font-weight:800;background:linear-gradient(135deg,#7c3aed,#ec4899);-webkit-background-clip:text;-webkit-text-fill-color:transparent;margin:8px 0;}
.plan .per{font-size:14px;color:#6b7280;}
.btn{display:inline-block;margin-top:12px;padding:10px 28px;border-radius:100px;font-size:14px;font-weight:600;border:none;cursor:pointer;color:white;}
.btn-primary{background:linear-gradient(135deg,#7c3aed,#6d28d9);}
.btn-gold{background:linear-gradient(135deg,#f59e0b,#f97316);}

</style>
<link rel="icon" type="image/x-icon" href="/assets/xianbao/favicon.ico">
<link rel="icon" type="image/png" sizes="16x16" href="/assets/xianbao/favicon-16.png">
<link rel="icon" type="image/png" sizes="32x32" href="/assets/xianbao/favicon-32.png">
<link rel="icon" type="image/png" sizes="192x192" href="/assets/xianbao/favicon-256.png">
<link rel="apple-touch-icon" sizes="180x180" href="/assets/xianbao/apple-touch-icon.png">
</head>
<body>

<link rel="stylesheet" href="/assets/xianbao/xianbao-topbar.css">
<div id="xianbao-topbar" data-active="reading"></div>
<div class="container">
  <h1>🌟 会员中心</h1>
  <div class="card">
    <div style="display:flex;align-items:center;gap:12px;">
      <div style="width:48px;height:48px;border-radius:50%;background:linear-gradient(135deg,#c4b5fd,#a78bfa);display:flex;align-items:center;justify-content:center;color:#5b21b6;font-size:20px;font-weight:700;">
        <%= (u.nickname||u.username)[0] %>
      <div>
        <div style="font-weight:600;"><%= u.nickname||u.username %></div>
        <div style="font-size:14px;color:#6b7280;"><%= u.is_vip ? '👑 仙宝心灵成长会员' : '普通用户' %></div>

  <% if (!u.is_vip) { %>
    <h2 style="text-align:center;font-size:18px;margin-bottom:20px;">开通会员，解锁全部内容</h2>
    <div class="plans">
      <div class="plan">
        <div style="font-size:32px;margin-bottom:4px;">🌙</div>
        <div style="font-weight:600;">月卡</div>
        <div class="price">¥29.9</div>
        <div class="per">每月续费</div>
        <button class="btn btn-primary" onclick="sub('monthly')">开通</button>
      <div class="plan featured">
        <div style="font-size:32px;margin-bottom:4px;">👑</div>
        <div style="font-weight:600;">年卡</div>
        <div class="price">¥299</div>
        <div class="per">每天不到1元</div>
        <button class="btn btn-gold" onclick="sub('annual')">开通</button>
  <% } else { %>
    <div class="card" style="text-align:center;">
      <div style="font-size:48px;margin-bottom:8px;">👑</div>
      <div style="font-size:18px;font-weight:600;">仙宝心灵成长会员已激活</div>
      <div style="font-size:14px;color:#6b7280;margin-top:4px;">有效期至: <%= u.vip_expires_at ? new Date(u.vip_expires_at).toLocaleDateString('zh-CN') : '永久' %></div>
      <a href="/books" class="btn btn-primary" style="margin-top:16px;">开始阅读</a>
  <% } %>

  <% if (reads.length > 0) { %>
    <h2 style="font-size:16px;margin:24px 0 12px;">📖 最近阅读</h2>
    <% reads.forEach(r => { %>
      <a href="/books/<%= r.book_id %>/read/<%= r.chapter_id %>" style="display:block;background:white;border-radius:8px;padding:12px 16px;margin-bottom:4px;text-decoration:none;color:inherit;">
        <div style="font-weight:500;"><%= r.bt %></div>
        <div style="font-size:14px;color:#9ca3af;"><%= r.ct||'' %> · <%= new Date(r.updated_at).toLocaleDateString('zh-CN') %></div>
      </a>
    <% }) %>
  <% } %>
<script>
async function sub(plan){
  var r=await fetch('/api/subscribe',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({plan})});
  var d=await r.json();
  if(d.ok){alert(d.msg);window.location.reload();}else alert(d.msg);
}
</script>
<script src="/assets/xianbao/auth-widget.js"></script>
<script src="/assets/xianbao/xianbao-topbar.js"></script>

</body>
</html>
