<%# Base layout template - provides shared HTML structure and styles %>
<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= typeof title !== 'undefined' ? title + ' - ' : '' %>仙宝心灵成长</title>
<link rel="stylesheet" href="/fontawesome/css/all.min.css">
<style>
*{margin:0;padding:0;box-sizing:border-box;}@font-face{font-family:'Noto Serif SC';src:url('/assets/xianbao/NotoSerifSC-SemiBold.subset.woff2')format('woff2');font-weight:600;font-display:swap}
body{font-family:-apple-system,BlinkMacSystemFont,'Noto Sans SC','PingFang SC','Hiragino Sans GB',sans-serif;background:#f8f5f0;color:#1f2937;padding-top:44px;font-size:1rem;}h1,h2,h3{font-family:'Songti SC','Noto Serif SC','STSong','SimSun',serif;font-weight:600}
a{color:#7c3aed;text-decoration:none;}
a:hover{opacity:.8;}

/* Container */
.container{max-width:1100px;margin:0 auto;padding:40px 20px;}

/* Buttons */
.btn{display:inline-block;padding:8px 20px;border-radius:100px;font-size:1rem;font-weight:600;text-decoration:none;border:none;cursor:pointer;transition:.2s;}
.btn:hover{opacity:.85;transform:translateY(-1px);}
.btn-primary{background:linear-gradient(135deg,#7c3aed,#6d28d9);color:white;}
.btn-outline{background:transparent;border:1px solid #7c3aed;color:#7c3aed;}
.btn-sm{padding:5px 14px;font-size:1rem;}

/* Badge */
.badge{font-size:1rem;padding:2px 10px;border-radius:100px;font-weight:600;}
.badge-free{background:#d1fae5;color:#059669;}
.badge-vip{background:#fef3c7;color:#d97706;}

/* Cards */
.card{background:white;border-radius:12px;overflow:hidden;border:1px solid rgba(0,0,0,.04);transition:.2s;}
.card:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,0,0,.08);}

/* Tags */
.tag{display:inline-block;padding:4px 12px;border-radius:100px;font-size:1rem;background:#f5f3ff;color:#7c3aed;margin-right:6px;margin-bottom:6px;}

/* Footer */
footer{background:#1e1b4b;margin-top:60px;}
.footer-inner{max-width:1100px;margin:0 auto;padding:28px 20px;text-align:center;color:rgba(255,255,255,.4);font-size:1rem;}
</style>
<link rel="icon" type="image/x-icon" href="/assets/xianbao/favicon.ico">
<link rel="icon" type="image/png" sizes="16x16" href="/assets/xianbao/favicon-16.png">
<link rel="icon" type="image/png" sizes="32x32" href="/assets/xianbao/favicon-32.png">
<link rel="icon" type="image/png" sizes="192x192" href="/assets/xianbao/favicon-256.png">
<link rel="apple-touch-icon" sizes="180x180" href="/assets/xianbao/apple-touch-icon.png">

<link rel="stylesheet" href="/assets/xianbao/xianbao-topbar.css">
</head>
<body>
<div id="xianbao-topbar" data-active="reading"></div>
<div class="container">
  <%- body %>
</div>
<%- include('./_footer') %>
<script src="/assets/xianbao/xianbao-topbar.js"></script>

</body>
</html>
